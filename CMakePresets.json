{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "POSIX",
      "hidden": true,
      "generator": "Ninja"
    },
    {
      "name": "DEBUG",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "DEBUG": "ON"
      }
    },
    {
      "name": "RELEASE",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "WASM",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake"
      }
    },

    {
      "name": "RPG",
      "hidden": true,
      "cacheVariables": {
        "GAME": "RPG"
      }
    },

    {
      "name": "CuZn",
      "hidden": true,
      "cacheVariables": {
        "GAME": "CuZn"
      }
    },
    {
      "name": "PINBALL",
      "hidden": true,
      "cacheVariables": {
        "GAME": "PINBALL"
      }
    },
    {
      "name": "WAR",
      "hidden": true,
      "cacheVariables": {
        "GAME": "WAR"
      }
    },
    {
      "name": "QNT",
      "hidden": true,
      "cacheVariables": {
        "GAME": "QNT"
      }
    },

    {
      "name": "RPG-POSIX-DEBUG",
      "inherits": ["POSIX", "DEBUG", "RPG"],
      "binaryDir": "build/RPG-${hostSystemName}-DEBUG"
    },
    {
      "name": "RPG-POSIX-RELEASE",
      "inherits": ["POSIX", "RELEASE", "RPG"],
      "binaryDir": "build/RPG-${hostSystemName}-RELEASE"
    },
    {
      "name": "RPG-WIN-DEBUG",
      "inherits": ["DEBUG", "RPG"],
      "binaryDir": "build/RPG-DEBUG"
    },
    {
      "name": "RPG-WIN-RELEASE",
      "inherits": ["RELEASE", "RPG"],
      "binaryDir": "build/RPG-RELEASE"
    },
    {
      "name": "RPG-WASM-RELEASE",
      "inherits": ["WASM", "RELEASE", "RPG"],
      "binaryDir": "build/RPG-WASM"
    },

    {
      "name": "CuZn-POSIX-DEBUG",
      "inherits": ["POSIX", "DEBUG", "CuZn"],
      "binaryDir": "build/CuZn-${hostSystemName}-DEBUG"
    },
    {
      "name": "CuZn-POSIX-RELEASE",
      "inherits": ["POSIX", "RELEASE", "CuZn"],
      "binaryDir": "build/CuZn-${hostSystemName}-RELEASE"
    },
    {
      "name": "CuZn-WIN-DEBUG",
      "inherits": ["DEBUG", "CuZn"],
      "binaryDir": "build/CuZn-DEBUG"
    },
    {
      "name": "CuZn-WIN-RELEASE",
      "inherits": ["RELEASE", "CuZn"],
      "binaryDir": "build/CuZn-RELEASE"
    },
    {
      "name": "CuZn-WASM-RELEASE",
      "inherits": ["WASM", "RELEASE", "CuZn"],
      "binaryDir": "build/CuZn-WASM"
    },

    {
      "name": "PINBALL-POSIX-DEBUG",
      "inherits": ["POSIX", "DEBUG", "PINBALL"],
      "binaryDir": "build/PINBALL-${hostSystemName}-DEBUG"
    },
    {
      "name": "PINBALL-POSIX-RELEASE",
      "inherits": ["POSIX", "RELEASE", "PINBALL"],
      "binaryDir": "build/PINBALL-${hostSystemName}-RELEASE"
    },
    {
      "name": "PINBALL-WIN-DEBUG",
      "inherits": ["DEBUG", "PINBALL"],
      "binaryDir": "build/PINBALL-DEBUG"
    },
    {
      "name": "PINBALL-WIN-RELEASE",
      "inherits": ["RELEASE", "PINBALL"],
      "binaryDir": "build/PINBALL-RELEASE"
    },

    {
      "name": "WAR-POSIX-DEBUG",
      "inherits": ["POSIX", "DEBUG", "WAR"],
      "binaryDir": "build/WAR-${hostSystemName}-DEBUG"
    },
    {
      "name": "WAR-POSIX-RELEASE",
      "inherits": ["POSIX", "RELEASE", "WAR"],
      "binaryDir": "build/WAR-${hostSystemName}-RELEASE"
    },
    {
      "name": "WAR-WIN-DEBUG",
      "inherits": ["DEBUG", "WAR"],
      "binaryDir": "build/WAR-DEBUG"
    },
    {
      "name": "WAR-WIN-RELEASE",
      "inherits": ["RELEASE", "WAR"],
      "binaryDir": "build/WAR-RELEASE"
    },

    {
      "name": "QNT-POSIX-DEBUG",
      "inherits": ["POSIX", "DEBUG", "QNT"],
      "binaryDir": "build/QNT-${hostSystemName}-DEBUG"
    },
    {
      "name": "QNT-POSIX-RELEASE",
      "inherits": ["POSIX", "RELEASE", "QNT"],
      "binaryDir": "build/QNT-${hostSystemName}-RELEASE"
    },
    {
      "name": "QNT-WIN-DEBUG",
      "inherits": ["DEBUG", "QNT"],
      "binaryDir": "build/QNT-DEBUG"
    },
    {
      "name": "QNT-WIN-RELEASE",
      "inherits": ["RELEASE", "QNT"],
      "binaryDir": "build/QNT-RELEASE"
    },
    {
      "name": "QNT-WASM-RELEASE",
      "inherits": ["WASM", "RELEASE", "QNT"],
      "binaryDir": "build/QNT-WASM"
    }
  ]
}